<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--
      Inserta un botón por línea en la grilla de invoice_line_ids del formulario de factura.
      XPath robusto: usamos field[1] dentro del <tree> para no depender de un nombre de campo específico.
      attrs:
        - Oculta en líneas de sección/notas (display_type != False).
        - Oculta si el documento no es de compra (parent.move_type no in in_invoice, in_refund, in_receipt).
    -->
    <record id="view_move_form_inherit_lc_button" model="ir.ui.view">
        <field name="name">account.move.form.inherit.lc.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//tree/field[1]" position="after">
                <button name="action_open_libro_compras_wizard"
                        type="object"
                        string="Libro Compras"
                        icon="fa-book"
                        attrs="{'invisible': ['|', ('display_type','!=', False), ('parent.move_type','not in', ['in_invoice','in_refund','in_receipt'])]}"/>
            </xpath>
        </field>
    </record>

    <!--
      Fallback opcional:
      Algunas personalizaciones usan line_ids (apuntando al tree de apuntes contables en la pestaña contable).
      Este bloque inserta el botón también ahí por si el usuario trabaja desde esa grilla.
      Se marca con priority mayor para aplicarse después si existe ese nodo en tu vista base.
    -->
    <record id="view_move_form_inherit_lc_button_fallback" model="ir.ui.view">
        <field name="name">account.move.form.inherit.lc.button.fallback</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='line_ids']//tree/field[1]" position="after">
                <button name="action_open_libro_compras_wizard"
                        type="object"
                        string="Libro Compras"
                        icon="fa-book"
                        attrs="{'invisible': ['|', ('display_type','!=', False), ('parent.move_type','not in', ['in_invoice','in_refund','in_receipt'])]}"/>
            </xpath>
        </field>
    </record>

</odoo>
