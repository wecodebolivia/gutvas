<!-- l10n_bo_purchase_book_line/views/account_move_views.xml -->
<odoo>
    <record id="view_move_line_purchase_book_form" model="ir.ui.view">
        <field name="name">account.move.line.purchase.book.form</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price_unit']" position="after">
                <field name="is_purchase_book_line"/>
                <field name="nit"/>
                <field name="invoice_number"/>
                <field name="authorization_number"/>
                <field name="control_code"/>
                <field name="purchase_amount"/>
                <field name="fiscal_credit"/>
            </xpath>
        </field>
    </record>
</odoo>
