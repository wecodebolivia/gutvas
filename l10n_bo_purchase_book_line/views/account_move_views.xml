<!-- l10n_bo_purchase_book_line/views/account_move_views.xml -->
<odoo>
    <!-- Heredar vista de factura de proveedor -->
    <record id="view_move_form_purchase_book_fields" model="ir.ui.view">
        <field name="name">account.move.purchase.book.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/tree" position="inside">
                <field name="is_purchase_book_line"/>
                <field name="nit"/>
                <field name="invoice_number"/>
                <field name="authorization_number"/>
                <field name="control_code"/>
                <field name="purchase_amount"/>
                <field name="fiscal_credit"/>
            </xpath>
        </field>
    </record>
</odoo>
