<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Botón en invoice_line_ids (vista de facturas) -->
    <record id="view_move_form_inherit_lc_on_invoice_lines" model="ir.ui.view">
        <field name="name">account.move.form.inherit.lc.on.invoice.lines</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Intento 1: estructura estándar -->
            <xpath expr="//field[@name='invoice_line_ids']/tree" position="inside">
                <button name="action_open_lc_fields" type="object" string="Libro de Compras"
                        icon="fa-book"
                        attrs="{'invisible': ['|', ('display_type','!=',False), ('move_id.move_type','not in', ('in_invoice','in_refund'))]}"/>
            </xpath>
            <!-- Intento 2: si es <list> (algunas localizaciones renombraron) -->
            <xpath expr="//field[@name='invoice_line_ids']//list" position="inside">
                <button name="action_open_lc_fields" type="object" string="Libro de Compras"
                        icon="fa-book"
                        attrs="{'invisible': ['|', ('display_type','!=',False), ('move_id.move_type','not in', ('in_invoice','in_refund'))]}"/>
            </xpath>
        </field>
    </record>

    <!-- Botón en line_ids (entradas de diario) -->
    <record id="view_move_form_inherit_lc_on_line_ids" model="ir.ui.view">
        <field name="name">account.move.form.inherit.lc.on.line.ids</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='line_ids']/tree" position="inside">
                <button name="action_open_lc_fields" type="object" string="Libro de Compras"
                        icon="fa-book"
                        attrs="{'invisible': ['|', ('display_type','!=',False), ('move_id.move_type','not in', ('in_invoice','in_refund'))]}"/>
            </xpath>
            <xpath expr="//field[@name='line_ids']//list" position="inside">
                <button name="action_open_lc_fields" type="object" string="Libro de Compras"
                        icon="fa-book"
                        attrs="{'invisible': ['|', ('display_type','!=',False), ('move_id.move_type','not in', ('in_invoice','in_refund'))]}"/>
            </xpath>
        </field>
    </record>
</odoo>
