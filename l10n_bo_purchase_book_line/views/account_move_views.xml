<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Botón en LÍNEAS DE FACTURA (invoice_line_ids) -->
    <record id="view_move_form_inherit_libro_compras" model="ir.ui.view">
        <field name="name">account.move.form.inherit.libro.compras.invoice_lines</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Soporta tanto <list> como <tree> según la versión -->
            <xpath expr="//field[@name='invoice_line_ids']//list | //field[@name='invoice_line_ids']//tree"
                   position="inside">
                <button name="action_open_libro_compras_wizard"
                        type="object"
                        string="Libro de Compras"
                        class="btn-link"
                        attrs="{'invisible': [('display_type','!=', False)]}"/>
            </xpath>
        </field>
    </record>

    <!-- Botón en APUNTES CONTABLES (line_ids) -->
    <record id="view_move_form_inherit_libro_compras_journal_items" model="ir.ui.view">
        <field name="name">account.move.form.inherit.libro.compras.journal.items</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='line_ids']//list | //field[@name='line_ids']//tree"
                   position="inside">
                <button name="action_open_libro_compras_wizard"
                        type="object"
                        string="Libro de Compras"
                        class="btn-link"
                        attrs="{'invisible': ['|', ('display_type','!=', False), ('move_id.move_type','not in', ['in_invoice','in_refund','in_receipt'])]}"/>
            </xpath>
        </field>
    </record>

</odoo>
