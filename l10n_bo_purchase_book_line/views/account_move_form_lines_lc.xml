<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- Heredamos el formulario base de account.move -->
  <record id="view_move_form_lines_lc" model="ir.ui.view">
    <field name="name">account.move.form.lines.add.lc.fields</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="priority" eval="90"/>
    <field name="arch" type="xml">

      <!-- Apuntamos al árbol del one2many line_ids y agregamos después de 'balance' -->
      <xpath expr="//field[@name='line_ids']//tree//field[@name='balance']" position="after">
        <field name="lc_importe_base_cf" optional="hide"/>
        <field name="lc_credito_fiscal" optional="hide"/>
      </xpath>

    </field>
  </record>
</odoo>
