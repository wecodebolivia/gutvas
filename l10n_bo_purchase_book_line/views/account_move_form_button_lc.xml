<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_move_form_add_lc_button" model="ir.ui.view">
    <field name="name">account.move.form.add.lc.button</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="priority" eval="90"/>
    <field name="arch" type="xml">
      <xpath expr="//div[@name='button_box']" position="inside">
        <button name="%(action_open_libro_compras_wizard)d"
                type="action"
                class="oe_stat_button"
                string="Libro de Compras"
                icon="fa-book"
                attrs="{'invisible': ['|', ('move_type','not in',['in_invoice','in_refund']), ('state','!=','posted')]}"/>
      </xpath>
    </field>
  </record>
</odoo>
