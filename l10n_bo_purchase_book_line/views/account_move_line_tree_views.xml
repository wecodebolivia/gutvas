<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>
    <!-- Botón y columnas en el listado base de líneas contables -->
    <record id="view_move_line_tree_lc_button" model="ir.ui.view">
      <field name="name">account.move.line.tree.lc.button</field>
      <field name="model">account.move.line</field>
      <field name="inherit_id" ref="account.view_move_line_tree"/>
      <field name="arch" type="xml">
        <xpath expr="//tree" position="inside">
          <field name="lc_importe_base_cf" optional="show"/>
          <field name="lc_credito_fiscal" optional="show"/>
          <button name="action_open_libro_compras_wizard"
                  type="object"
                  string="Libro Compras"
                  icon="fa-book"/>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
