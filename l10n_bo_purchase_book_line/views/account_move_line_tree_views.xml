<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- Añade las columnas del Libro de Compras en el listado de apuntes -->
  <record id="view_move_line_tree_lc_button" model="ir.ui.view">
    <field name="name">account.move.line.tree.add.lc.fields</field>
    <field name="model">account.move.line</field>
    <!-- Importante: heredar del árbol correcto -->
    <field name="inherit_id" ref="account.view_move_line_tree"/>
    <field name="priority" eval="90"/>
    <field name="arch" type="xml">
      <!-- En lugar de //tree, anclamos a un campo que existe en el árbol base -->
      <xpath expr="//field[@name='balance']" position="after">
        <field name="lc_importe_base_cf" optional="hide"/>
        <field name="lc_credito_fiscal" optional="hide"/>
      </xpath>
    </field>
  </record>
</odoo>
