<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cucu_rent_anulation_wizard_form" model="ir.ui.view">
        <field name="name">cucu.rent.anulation.wizard.form</field>
        <field name="model">cucu.rent.anulation.wizard</field>
        <field name="arch" type="xml">
            <form string="Anular / Revertir Factura Alquiler">
                <sheet>
                    <group>
                        <field name="confirm_message" readonly="1"
                               attrs="{'invisible': [('confirm_message', '=', False)]}"/>
                    </group>
                    <group>
                        <field name="motive" required="1"/>
                    </group>
                    <div class="alert alert-warning" role="alert">
                        Esta operación se enviará a CUCU y al SIN.
                        No se puede deshacer desde Odoo.
                    </div>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Confirmar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>