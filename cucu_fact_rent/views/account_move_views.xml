<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========== 1. Botones en el HEADER ========== -->
    <record id="view_move_form_rent_header" model="ir.ui.view">
        <field name="name">account.move.form.rent.header</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_rent_invoice_cucu"
                        string="&#128228; Enviar a CUCU"
                        type="object" class="btn-primary"
                        invisible="not is_rent_invoice or state != 'posted' or cucu_rent_cuf"/>
                <button name="action_recover_rent_invoice_data"
                        string="&#128260; Recuperar de CUCU"
                        type="object" class="btn-secondary"
                        invisible="not is_rent_invoice or not cucu_rent_cuf or cucu_rent_state == 'cancelled'"/>
                <button name="action_anulate_rent_invoice_wizard"
                        string="&#128683; Anular"
                        type="object" class="btn-danger"
                        invisible="not is_rent_invoice or not cucu_rent_cuf or cucu_rent_state == 'cancelled'"/>
                <button name="action_revert_rent_invoice_wizard"
                        string="&#8617;&#65039; Revertir"
                        type="object" class="btn-warning"
                        invisible="not is_rent_invoice or not cucu_rent_cuf or cucu_rent_state == 'cancelled'"/>
            </xpath>
        </field>
    </record>

    <!-- ========== 2. Toggle en header_left_group (solo form) ========== -->
    <record id="view_move_form_rent_toggle" model="ir.ui.view">
        <field name="name">account.move.form.rent.toggle</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='header_left_group']" position="inside">
                <field name="is_rent_invoice" widget="boolean_toggle"
                       string="Factura de Alquiler"/>
            </xpath>
        </field>
    </record>

    <!-- ========== 3. Grupo de campos en el SHEET (solo form) ========== -->
    <record id="view_move_form_rent_fields" model="ir.ui.view">
        <field name="name">account.move.form.rent.fields</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form//sheet//group" position="after">
                <group id="group_rent_invoice" invisible="not is_rent_invoice">

                    <group string="Datos del Alquiler">
                        <field name="rent_billed_period"
                               required="is_rent_invoice"
                               placeholder="Ej: Marzo 2026"
                               string="Período Facturado"/>
                        <field name="rent_property_address"
                               placeholder="Ej: Av. Arce 1234, piso 3"
                               string="Dirección del Inmueble"/>
                    </group>

                    <group string="Estado CUCU">
                        <field name="cucu_rent_state"
                               string="Estado"
                               widget="badge"
                               decoration-success="cucu_rent_state == 'validated'"
                               decoration-danger="cucu_rent_state in ('rejected', 'cancelled')"
                               decoration-warning="cucu_rent_state == 'sent'"
                               decoration-muted="cucu_rent_state == 'draft'"/>
                        <field name="cucu_rent_cuf"
                               string="CUF"
                               readonly="1"
                               invisible="not cucu_rent_cuf"/>
                    </group>

                    <group string="Datos Técnicos (recuperación manual)"
                           invisible="not cucu_rent_invoice_code and not cucu_rent_invoice_number">
                        <field name="cucu_rent_invoice_code"
                               string="Invoice Code"
                               placeholder="Ej: B14C0F32"
                               help="Solo necesario para recuperar datos de facturas emitidas sin CUF."/>
                        <field name="cucu_rent_invoice_number"
                               string="Número Factura"
                               placeholder="Ej: 2"
                               help="Número correlativo SIN. Solo para recuperación manual."/>
                    </group>

                </group>
            </xpath>
        </field>
    </record>

    <!-- ========== 4. VISTA DE LISTA ========== 
    <record id="view_invoice_tree_rent" model="ir.ui.view">
        <field name="name">account.move.tree.rent</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="rent_billed_period" optional="show" string="Período"/>
                <field name="cucu_rent_state" optional="show" widget="badge"
                       string="Estado CUCU"
                       decoration-success="cucu_rent_state == 'validated'"
                       decoration-danger="cucu_rent_state in ('rejected','cancelled')"
                       decoration-warning="cucu_rent_state == 'sent'"/>
            </xpath>
        </field>
    </record>-->

    <!-- ========== 5. FILTROS ========== -->
    <record id="view_account_invoice_filter_rent" model="ir.ui.view">
        <field name="name">account.move.filter.rent</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='draft']" position="after">
                <separator/>
                <filter string="&#127968; Alquileres" name="rent_invoices"
                        domain="[('is_rent_invoice', '=', True)]"/>
                <filter string="&#9989; Enviadas a SIN" name="with_rent_cuf"
                        domain="[('cucu_rent_cuf', '!=', False)]"/>
                <filter string="&#10060; Rechazadas" name="rent_rejected"
                        domain="[('cucu_rent_state', '=', 'rejected')]"/>
                <filter string="&#128683; Anuladas" name="rent_cancelled"
                        domain="[('cucu_rent_state', '=', 'cancelled')]"/>
            </xpath>
        </field>
    </record>

</odoo>
