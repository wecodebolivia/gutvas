<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========== FORMULARIO: toggle + botón al final de header_left_group ========== -->
    <!-- priority=20 garantiza que se ejecuta después de cucu_fact_core (priority=16)    -->
    <!-- que es quien agrega is_sin al grupo. Así el toggle queda justo debajo de is_sin -->
    <record id="view_move_form_rent_is_sin" model="ir.ui.view">
        <field name="name">account.move.form.rent.is_sin</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <xpath expr="//group[@id='header_left_group']" position="inside">
                <field name="is_rent_invoice"
                       widget="boolean_toggle"
                       invisible="not is_sin"
                       options="{'autosave': False}"/>
                <label for="is_rent_invoice"
                       string="Factura Alquileres"
                       invisible="not is_sin"/>
                <button name="action_send_rent_invoice_cucu"
                        string="&#128228; Enviar a CUCU (Alquileres)"
                        type="object"
                        class="btn btn-primary mt-1"
                        invisible="not is_sin or not is_rent_invoice or state != 'posted' or cucu_rent_cuf"
                        icon="fa-paper-plane"
                        help="Enviar factura a CUCU API para obtener CUF"/>
            </xpath>

        </field>
    </record>

    <!-- ========== FORMULARIO: campos específicos + pestaña alquileres ========== -->
    <record id="view_move_form_rent_invoice" model="ir.ui.view">
        <field name="name">account.move.form.rent.invoice</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Período facturado y tipo operación junto a invoice_date -->
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="rent_billed_period"
                       invisible="not is_rent_invoice"
                       required="is_rent_invoice"
                       placeholder="Ej: Mayo 2026"/>
                <field name="rent_type_operation"
                       invisible="not is_rent_invoice"/>
            </xpath>

            <!-- Pestaña adicional: Datos Alquileres -->
            <xpath expr="//notebook" position="inside">
                <page string="&#127968; Datos Alquileres"
                      name="rent_data"
                      invisible="not is_rent_invoice">

                    <group>
                        <group string="Información del Inmueble">
                            <field name="rent_property_address"
                                   placeholder="Dirección completa del inmueble en alquiler"/>
                        </group>

                        <group string="Estado CUCU">
                            <field name="cucu_rent_state"
                                   widget="badge"
                                   decoration-success="cucu_rent_state == 'validated'"
                                   decoration-danger="cucu_rent_state == 'rejected'"
                                   decoration-warning="cucu_rent_state == 'sent'"
                                   decoration-muted="cucu_rent_state == 'draft'"/>
                            <field name="cucu_rent_cuf"
                                   readonly="1"
                                   widget="CopyClipboardChar"/>
                        </group>
                    </group>

                    <separator string="Respuesta CUCU API"/>
                    <field name="cucu_rent_response"
                           readonly="1"
                           widget="ace"
                           options="{'mode': 'json'}"
                           invisible="not cucu_rent_response"/>

                </page>
            </xpath>

        </field>
    </record>

    <!-- ========== VISTA DE LISTA ========== -->
    <record id="view_invoice_tree_rent" model="ir.ui.view">
        <field name="name">account.move.tree.rent</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_rent_invoice"
                       optional="show"
                       widget="boolean_toggle"/>
                <field name="cucu_rent_state"
                       optional="hide"
                       widget="badge"
                       decoration-success="cucu_rent_state == 'validated'"
                       decoration-danger="cucu_rent_state == 'rejected'"/>
                <field name="cucu_rent_cuf"
                       optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- ========== FILTROS DE BÚSQUEDA ========== -->
    <record id="view_account_invoice_filter_rent" model="ir.ui.view">
        <field name="name">account.move.filter.rent</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='draft']" position="after">
                <separator/>
                <filter string="&#127968; Facturas Alquileres"
                        name="rent_invoices"
                        domain="[('is_rent_invoice', '=', True)]"/>
                <filter string="&#9989; Con CUF (Alquileres)"
                        name="with_rent_cuf"
                        domain="[('cucu_rent_cuf', '!=', False)]"/>
                <filter string="&#10060; Rechazadas (Alquileres)"
                        name="rent_rejected"
                        domain="[('cucu_rent_state', '=', 'rejected')]"/>
            </xpath>
        </field>
    </record>

</odoo>
