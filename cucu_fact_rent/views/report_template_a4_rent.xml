<!-- Reporte A4 específico para Facturas de Alquiler (cucu_fact_rent) -->
<odoo>
    <data>
        <!--
            Este template hereda el reporte base A4 de cucu_fact_report
            y sobrescribe únicamente los elementos específicos para
            la Factura de Alquiler:
              1. Título: "FACTURA DE ALQUILER" + PERÍODO FACTURADO destacado
              2. Período Facturado: campo adicional junto a Cod. Cliente
              3. Dirección Inmueble: se muestra debajo de la descripción
                 en la tabla de detalle
        -->
        <template id="report_a4_rent_title" inherit_id="cucu_fact_report.cucu_report_a4">

            <!-- 1. SOBRESCRIBIR TÍTULO: reemplaza todo el div.text-center -->
            <xpath expr="//div[@class='text-center']" position="replace">
                <div class="text-center">
                    <t t-if="header['doc_sector'] == 1">
                        <t t-if="o.is_rent_invoice">
                            <div class="text-2xl font-bold uppercase"
                                 t-attf-style="color: #{o.company_id.color_primary};">
                                FACTURA DE ALQUILER
                            </div>
                            <div style="font-size:12px; font-weight: 600;">
                                (CON DERECHO A CRÉDITO FISCAL)
                            </div>
                            <!-- PERÍODO FACTURADO destacado bajo el título -->
                            <t t-if="o.rent_billed_period">
                                <div t-attf-style="
                                        display: inline-block;
                                        margin-top: 5px;
                                        padding: 3px 14px;
                                        background-color: #{o.company_id.color_primary};
                                        color: #ffffff;
                                        font-size: 11px;
                                        font-weight: 700;
                                        letter-spacing: 0.5px;
                                        border-radius: 3px;
                                        text-transform: uppercase;
                                    ">
                                    PERÍODO FACTURADO:&#160;<t t-esc="o.rent_billed_period.upper() if o.rent_billed_period else ''"/>
                                </div>
                            </t>
                        </t>
                        <t t-else="">
                            <div class="text-4xl font-bold"
                                 t-attf-style="color: #{o.company_id.color_primary};">
                                Factura
                            </div>
                            <div style="font-size:13px">(Con Derecho a Crédito Fiscal)</div>
                        </t>
                    </t>
                    <t t-if="header['doc_sector'] == 24">
                        <div class="font-bold"
                             t-attf-style="color: #{o.company_id.color_primary};font-size: 24px;">
                            NOTA CRÉDITO-DÉBITO
                        </div>
                    </t>
                </div>
            </xpath>

            <!-- 2. AGREGAR "PERIODO FACTURADO" en la columna derecha del cliente -->
            <xpath expr="//div[@id='invoice_client_right']//table" position="inside">
                <t t-if="o.is_rent_invoice and o.rent_billed_period">
                    <tr>
                        <td class="font-bold min-w-[180px] text-left pr-2 align-text-top"
                            t-attf-style="color: #{o.company_id.color_primary};">
                            Periodo Facturado:
                        </td>
                        <td class="text-sm">
                            <div style="font-weight: 600;"
                                 t-esc="o.rent_billed_period.upper() if o.rent_billed_period else ''"/>
                        </td>
                    </tr>
                </t>
            </xpath>

            <!-- 3. DIRECCIÓN INMUEBLE debajo de la descripción en cada fila del detalle -->
            <!--    Reemplaza la celda td de descripcion en el tbody de invoice_sale -->
            <xpath expr="//div[@id='invoice_sale']//tbody//td[@class='text-left px-1 py-1']" position="replace">
                <td class="text-left px-1 py-1" style="vertical-align: middle;">
                    <div t-esc="line['descripcion']"/>
                    <t t-if="o.is_rent_invoice and header.get('dirInmueble')">
                        <div style="font-size:0.70rem; color:#555; margin-top:2px;"
                             t-esc="header['dirInmueble']"/>
                    </t>
                </td>
            </xpath>

        </template>
    </data>
</odoo>
